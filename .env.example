# PHPNuxBill Environment Configuration
# Copy this file to .env and update the values according to your environment
# 
# IMPORTANT: Never commit .env to version control!

# Application Stage (Live, Dev, Demo)
APP_STAGE=Live

# Database Configuration - PHPNuxBill Main Database
DB_HOST=localhost
DB_PORT=
DB_USER=root
DB_PASS=
DB_NAME=phpnuxbill

# Optional: Radius Database Configuration
# RADIUS_HOST=localhost
# RADIUS_USER=root
# RADIUS_PASS=
# RADIUS_NAME=radius

# Optional: HTTP Proxy Configuration
# HTTP_PROXY=proxy.example.com:8080
# HTTP_PROXYAUTH=username:password

# Optional: API Secret Key
# API_SECRET=your-secret-key-here

# Optional: Application URL (auto-detected if not set)
# APP_URL=http://localhost/phpnuxbill
